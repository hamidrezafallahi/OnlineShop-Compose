# =============================================================================
# OnlineShop - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ─── SQL Server ──────────────────────────────────────────────────────────
# Generate a strong password (min 8 chars with upper, lower, digits, special)
SQL_SA_PASSWORD=H@mid1991
# ─── JWT ─────────────────────────────────────────────────────────────────
# Generate a 256-bit key: openssl rand -hex 32
JWT_KEY=oP+8s8cH9Z2K3n0Q4b1Vd3t6W+XjR7LqF5aM8zYhQvN1uC6pR0sTgH2kJ9lE4wF7
JWT_ISSUER=OnlineShop
JWT_AUDIENCE=OnlineShopUsers
# ─── Backend ─────────────────────────────────────────────────────────────
BACKEND_PORT=8080
# ─── Frontend ────────────────────────────────────────────────────────────
# External URL (used in browser) — for dev use http://localhost
NEXT_PUBLIC_APP_URL=https://shooshkitchen.ir
# API URL as seen from the browser — goes through nginx
NEXT_PUBLIC_API_URL=https://shooshkitchen.ir
# Internal API URL for server-side calls — direct to backend container
INTERNAL_API_URL=http://backend:8080
# ─── Docker ─────────────────────────────────────────────────────────────────
DOCKER_USERNAME=hamidrezafalahi
COMPOSE_PROJECT_NAME=shop
# ─── Certbot ─────────────────────────────────────────────────────────────────
CERTBOT_EMAIL=hamidreza.lipar@gmail.com
# ─── Nginx ───────────────────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443
# ─── Domain (Production Only) ────────────────────────────────────────────
DOMAIN_NAME=shooshkitchen.ir

