# ─── Frontend Development ───────────────────────────────────────────────────
# Purpose: Fast startup with hot-reload via Next.js dev server
# Source code is mounted as a volume; node_modules are installed in the image.

FROM node:22.19.0-alpine3.22 AS base

LABEL maintainer="OnlineShop Team" \
      description="OnlineShop Frontend - Development" \
      version="1.0"

WORKDIR /app

# Install dependencies first (cached layer unless package.json changes)
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

ENV NODE_ENV=development
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1

# Next.js dev server with hot-reload
CMD ["yarn", "dev"]