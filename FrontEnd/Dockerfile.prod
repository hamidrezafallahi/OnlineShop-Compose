# ─── Frontend Production ─────────────────────────────────────────────────────
# Multi-stage build with standalone output for minimal image size.
# ==============================================================================

# ─── Stage 1: Dependencies ────────────────────────────────────────────────────
FROM node:22.19.0-alpine3.22 AS deps

LABEL maintainer="OnlineShop Team" \
      description="OnlineShop Frontend - Dependencies" \
      version="1.0"

WORKDIR /app

# Copy package files for layer caching
COPY package.json yarn.lock ./

# Install production dependencies only first (cached layer)
RUN yarn install --frozen-lockfile --production \
    && cp -R node_modules /prod_node_modules \
    # Then install all dependencies for build
    && yarn install --frozen-lockfile

# ─── Stage 2: Builder ────────────────────────────────────────────────────────
FROM node:22.19.0-alpine3.22 AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build the Next.js application
RUN yarn build

# ─── Stage 3: Runner ─────────────────────────────────────────────────────────
FROM node:22.19.0-alpine3.22 AS runner

LABEL maintainer="OnlineShop Team" \
      description="OnlineShop Frontend - Production" \
      version="1.0"

WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1

# Copy standalone output (minimal set of files needed to run)
COPY --from=builder --chown=nextjs:nodejs /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Security: remove package managers from runtime
RUN rm -f /usr/local/bin/yarn /usr/local/bin/npm /usr/local/bin/npx 2>/dev/null || true

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

# Standalone output provides server.js
CMD ["node", "server.js"]